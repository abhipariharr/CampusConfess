<div class="row justify-content-center g-4">
  <div class="col-lg-7">

    <!-- ── Instagram-style Profile Header ── -->
    <div class="profile-header">
      <!-- Avatar with story ring -->
      <div class="story-ring" style="width:88px;height:88px;flex-shrink:0">
        <div class="story-ring-inner" style="background:<%= user.avatar_color||'#7c3aed' %>;font-size:2rem">
          <%= user.anon_username.charAt(0) %>
        </div>
      </div>

      <!-- Info -->
      <div class="flex-grow-1">
        <div class="d-flex align-items-center gap-3 flex-wrap mb-2">
          <div class="profile-username"><%= user.anon_username %></div>
          <button class="btn btn-ghost btn-sm" data-bs-toggle="collapse" data-bs-target="#editSection" style="border-radius:8px!important">Edit Profile</button>
        </div>
        <!-- Stats row -->
        <div class="profile-stats">
          <div class="profile-stat">
            <span class="profile-stat-val"><%= interests.length %></span>
            <span class="profile-stat-lbl">interests</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-val">🎭</span>
            <span class="profile-stat-lbl">anonymous</span>
          </div>
          <div class="profile-stat">
            <span class="profile-stat-val">
              <%= new Date(user.created_at).toLocaleDateString('en-US',{month:'short',year:'numeric'}) %>
            </span>
            <span class="profile-stat-lbl">joined</span>
          </div>
        </div>
        <!-- Bio -->
        <% if (user.bio) { %>
        <div class="profile-bio-text"><%= user.bio %></div>
        <% } else { %>
        <div style="font-size:13px;color:var(--text-3);font-style:italic">No bio yet — add one!</div>
        <% } %>
        <!-- Privacy badge -->
        <div style="margin-top:.6rem;font-size:12px;color:var(--text-3);display:flex;align-items:center;gap:.35rem">
          🛡️ Real name never shown to anyone
        </div>
      </div>
    </div>

    <!-- ── Edit Form (collapsible) ── -->
    <div class="collapse show" id="editSection">
      <form action="/profile" method="POST" id="profileForm">

        <div class="mb-3">
          <label for="gender" class="form-label">Gender</label>
          <select id="gender" name="gender" class="form-control">
            <option value="" <%= !user.gender ? 'selected' : '' %>>Prefer not to say</option>
            <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
            <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
            <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Other</option>
          </select>
          <div style="font-size:11px;color:var(--text-3);margin-top:.35rem">Used for opposite-gender random chat matching</div>
        </div>

        <div class="mb-3">
          <label for="bio" class="form-label">Bio <span style="color:var(--text-3);font-weight:400">(no identifying info)</span></label>
          <textarea id="bio" name="bio" class="form-control" rows="2" maxlength="300"
            placeholder="Something about you, anonymously..."><%= user.bio || '' %></textarea>
          <div class="d-flex justify-content-end mt-1">
            <span style="font-size:11px;color:var(--text-3)" id="bioCount"><%= (user.bio||'').length %>/300</span>
          </div>
        </div>

        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <label class="form-label mb-0">Interests <span style="color:var(--text-3);font-weight:400">(used for matching)</span></label>
            <span style="font-size:12px;color:var(--text-3)" id="interestCount"><%= interests.length %>/10 selected</span>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <% allInterests.forEach(i => { %>
            <label class="interest-chip <%= interests.includes(i)?'active':'' %>">
              <input type="checkbox" name="interests" value="<%= i %>" <%= interests.includes(i)?'checked':'' %> class="d-none interest-cb">
              <%= i %>
            </label>
            <% }) %>
          </div>
        </div>

        <button type="submit" class="btn btn-glow w-100 py-2">Save Changes</button>
      </form>
    </div>
  </div>

  <!-- ── Right sidebar ── -->
  <div class="col-lg-4 d-none d-lg-block">
    <div style="position:sticky;top:80px">
      <div class="sidebar-title">Quick Links</div>
      <a href="/confessions/new" class="sidebar-action-btn"><span class="emoji">🤫</span> Post Confession</a>
      <a href="/match" class="sidebar-action-btn"><span class="emoji">💜</span> Find Matches</a>
      <a href="/chat" class="sidebar-action-btn"><span class="emoji">💬</span> Open Chat</a>
    </div>
  </div>
</div>

<script>
const bioEl = document.getElementById('bio');
const bioCount = document.getElementById('bioCount');
bioEl.addEventListener('input', () => bioCount.textContent = `${bioEl.value.length}/300`);

const countEl = document.getElementById('interestCount');
let sel = document.querySelectorAll('.interest-cb:checked').length;
document.querySelectorAll('.interest-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const cb = chip.querySelector('.interest-cb');
    if (!cb.checked && sel >= 10) return;
    cb.checked = !cb.checked;
    chip.classList.toggle('active', cb.checked);
    sel = document.querySelectorAll('.interest-cb:checked').length;
    countEl.textContent = `${sel}/10 selected`;
  });
});
</script>
