<div class="row justify-content-center">
  <div class="col-lg-7 col-xl-6">

    <div class="mb-3">
      <a href="/confessions" style="color:var(--text-3);font-size:.85rem;text-decoration:none"><i class="bi bi-arrow-left me-1"></i>Back to Feed</a>
    </div>

    <div class="card p-4 p-md-5" style="border-radius:24px!important">
      <div class="mb-4">
        <div style="font-size:2.5rem;margin-bottom:.75rem">🤫</div>
        <h2 class="fw-bold mb-1" style="font-size:1.5rem">Drop a Confession</h2>
        <p style="color:var(--text-2);font-size:.875rem">Anonymous. Always. This will post under <strong style="color:#c084fc"><%= user.anon_username %></strong> — not your real name.</p>
      </div>

      <form action="/confessions" method="POST" id="postForm">
        <div class="mb-4">
          <label for="content" class="form-label">What's on your mind? ✨</label>
          <textarea id="content" name="content" class="form-control" rows="6"
            placeholder="Confess your truth... be honest, be real. Zero judgment here 💜"
            minlength="10" maxlength="1500" required
            style="resize:none;font-size:.95rem;line-height:1.7"></textarea>
          <div class="d-flex justify-content-between mt-1">
            <span style="font-size:.72rem;color:var(--text-3)">Minimum 10 characters</span>
            <span style="font-size:.72rem;color:var(--text-3)" id="charCount">0 / 1500</span>
          </div>
        </div>

        <div class="mb-4">
          <label class="form-label">Vibe <span style="color:var(--text-3);font-weight:400">(pick one or more)</span></label>
          <div class="d-flex flex-wrap gap-2 mb-2">
            <% [
              {tag:'love',emoji:'❤️'},
              {tag:'rant',emoji:'😤'},
              {tag:'funny',emoji:'😂'},
              {tag:'study',emoji:'📚'},
              {tag:'thoughts',emoji:'💭'},
              {tag:'wholesome',emoji:'🥰'},
              {tag:'advice',emoji:'🧠'},
              {tag:'secret',emoji:'🤫'},
              {tag:'embarrassing',emoji:'😳'},
              {tag:'friendship',emoji:'🤝'},
            ].forEach(({tag,emoji}) => { %>
            <button type="button" class="badge-tag tag-pick" data-tag="<%= tag %>"><%= emoji %> <%= tag %></button>
            <% }) %>
          </div>
          <input type="hidden" name="tags" id="tagsInput" value="">
        </div>

        <button type="submit" class="btn btn-glow w-100 py-2" id="postBtn" style="font-size:1rem">
          Post Anonymously 🎭
        </button>
      </form>
    </div>
  </div>
</div>

<script>
const contentEl = document.getElementById('content');
const charCount  = document.getElementById('charCount');
const tagsInput  = document.getElementById('tagsInput');
let selectedTags = [];

contentEl.addEventListener('input', () => {
  const len = contentEl.value.length;
  charCount.textContent = `${len} / 1500`;
  charCount.style.color = len > 1400 ? '#f87171' : 'var(--text-3)';
});

document.querySelectorAll('.tag-pick').forEach(btn => {
  btn.addEventListener('click', () => {
    const tag = btn.dataset.tag;
    if (selectedTags.includes(tag)) {
      selectedTags = selectedTags.filter(t => t !== tag);
      btn.classList.remove('active');
    } else if (selectedTags.length < 5) {
      selectedTags.push(tag);
      btn.classList.add('active');
    }
    tagsInput.value = selectedTags.join(',');
  });
});

document.getElementById('postForm').addEventListener('submit', () => {
  const btn = document.getElementById('postBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Posting...';
});
</script>
