<nav class="navbar navbar-dark sticky-top glass-nav">
  <div class="container-fluid px-3 px-md-4 d-flex align-items-center" style="height:60px">

    <!-- Brand -->
    <a class="navbar-brand d-flex align-items-center gap-2 text-decoration-none me-auto" href="/">
      <div style="width:30px;height:30px;border-radius:8px;background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0">🎭</div>
      <span class="brand-name" style="font-size:1.1rem">CampusWhisper</span>
    </a>

    <!-- Desktop nav links (hidden on mobile) -->
    <% if (locals.user) { %>
    <div class="d-none d-lg-flex align-items-center gap-1 mx-auto">
      <a class="nav-link nav-pill" href="/confessions"><i class="bi bi-house me-1"></i>Feed</a>
      <a class="nav-link nav-pill" href="/confessions/new"><i class="bi bi-plus-square me-1"></i>Confess</a>
      <a class="nav-link nav-pill" href="/chat"><i class="bi bi-chat-bubble me-1"></i>Chat</a>
      <a class="nav-link nav-pill" href="/match"><i class="bi bi-heart me-1"></i>Match</a>
    </div>
    <% } %>

    <!-- Right: User avatar & dropdown -->
    <div class="d-flex align-items-center gap-2 ms-auto">
      <% if (locals.user) { %>
        <% if (user.role === 'admin') { %>
        <a href="/admin" class="d-none d-md-flex align-items-center justify-content-center"
           style="width:32px;height:32px;border-radius:8px;background:rgba(251,191,36,.1);color:#fbbf24;text-decoration:none">
          <i class="bi bi-shield-check"></i>
        </a>
        <% } %>

        <!-- Search button -->
        <button class="d-flex align-items-center justify-content-center border-0"
                id="searchToggle"
                style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.06);color:var(--text-2)">
          <i class="bi bi-search" style="font-size:14px"></i>
        </button>
        <!-- Search dropdown -->
        <div class="dropdown-menu dropdown-menu-end glass-dropdown mt-2 p-0" id="searchDropdown" style="width:300px;display:none">
          <form action="/confessions" method="GET" class="p-2">
            <div class="input-group">
              <input type="text" name="search" class="form-control" placeholder="Search confessions..." id="searchInput" autocomplete="off">
              <button type="submit" class="btn btn-gradient"><i class="bi bi-search"></i></button>
            </div>
          </form>
        </div>

        <!-- Notification bell -->
        <button class="d-flex align-items-center justify-content-center border-0 position-relative"
                id="notifBell"
                style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.06);color:var(--text-2)">
          <i class="bi bi-bell" style="font-size:14px"></i>
          <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                style="font-size:10px;display:none">0</span>
        </button>
        <!-- Notification dropdown -->
        <div class="dropdown-menu dropdown-menu-end glass-dropdown mt-2 p-0" id="notifDropdown"
             style="width:320px;max-height:400px;overflow-y:auto;display:none">
          <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom" style="border-color:var(--border)">
            <span style="font-weight:700;font-size:14px">Notifications</span>
            <button class="btn btn-link p-0 text-decoration-none" id="markAllRead" style="font-size:12px;color:var(--accent)">Mark all read</button>
          </div>
          <div id="notifList"></div>
        </div>

        <!-- Avatar dropdown -->
        <div class="dropdown">
          <button class="d-flex align-items-center gap-0 border-0 bg-transparent p-0" style="cursor:pointer" data-bs-toggle="dropdown">
            <div class="story-ring" style="width:36px;height:36px">
              <div class="story-ring-inner" style="background:<%= user.avatar_color||'#7c3aed' %>;font-size:.8rem">
                <%= user.anon_username.charAt(0) %>
              </div>
            </div>
          </button>
          <ul class="dropdown-menu dropdown-menu-end glass-dropdown mt-2">
            <li class="px-2 py-1 mb-1">
              <div class="d-flex align-items-center gap-2 px-1">
                <div class="story-ring" style="width:32px;height:32px;flex-shrink:0">
                  <div class="story-ring-inner" style="background:<%= user.avatar_color||'#7c3aed' %>;font-size:.72rem"><%= user.anon_username.charAt(0) %></div>
                </div>
                <div>
                  <div style="font-weight:700;font-size:13px"><%= user.anon_username %></div>
                  <div style="font-size:11px;color:var(--text-3)">Anonymous</div>
                </div>
              </div>
            </li>
            <li><hr class="dropdown-divider" style="border-color:var(--border);margin:.25rem 0"></li>
            <li><a class="dropdown-item" href="/profile"><i class="bi bi-person me-2"></i>Profile</a></li>
            <li><a class="dropdown-item" href="/confessions/new"><i class="bi bi-plus-square me-2"></i>New Confession</a></li>
            <% if (user.role === 'admin') { %>
            <li><a class="dropdown-item" href="/admin" style="color:#fbbf24"><i class="bi bi-shield-check me-2"></i>Admin Panel</a></li>
            <% } %>
            <li><hr class="dropdown-divider" style="border-color:var(--border);margin:.25rem 0"></li>
            <li><a class="dropdown-item" href="/logout" style="color:var(--red)"><i class="bi bi-box-arrow-right me-2"></i>Log Out</a></li>
          </ul>
        </div>

      <% } else { %>
        <a href="/login" class="btn btn-ghost btn-sm">Log In</a>
        <a href="/signup" class="btn btn-gradient btn-sm">Sign Up</a>
      <% } %>
    </div>
  </div>
</nav>

<script>
document.getElementById('searchToggle').addEventListener('click', (e) => {
  e.stopPropagation();
  const dropdown = document.getElementById('searchDropdown');
  const isOpen = dropdown.style.display !== 'none';
  dropdown.style.display = isOpen ? 'none' : 'block';
  if (!isOpen) document.getElementById('searchInput').focus();
});
document.addEventListener('click', () => {
  document.getElementById('searchDropdown').style.display = 'none';
});
document.getElementById('searchDropdown').addEventListener('click', (e) => e.stopPropagation());

// ─── Notifications ──────────────────────────────────────────────────────────
const notifBell = document.getElementById('notifBell');
const notifDropdown = document.getElementById('notifDropdown');
const notifBadge = document.getElementById('notifBadge');
const notifList = document.getElementById('notifList');

notifBell && notifBell.addEventListener('click', (e) => {
  e.stopPropagation();
  notifDropdown.style.display = notifDropdown.style.display !== 'none' ? 'none' : 'block';
  if (notifDropdown.style.display === 'block') {
    document.getElementById('searchDropdown').style.display = 'none';
    socket.emit('get_notifications');
  }
});
document.addEventListener('click', () => { notifDropdown.style.display = 'none'; });
notifDropdown && notifDropdown.addEventListener('click', (e) => e.stopPropagation());

// Socket listeners
if (typeof socket !== 'undefined') {
  socket.on('notifications', ({ notifications }) => {
    renderNotifications(notifications);
  });

  socket.on('new_notification', ({ notification }) => {
    const badge = document.getElementById('notifBadge');
    const count = parseInt(badge.textContent) || 0;
    badge.textContent = count + 1;
    badge.style.display = 'block';
    // Prepend to list
    const item = createNotifItem(notification);
    if (notifList.firstChild) {
      notifList.insertBefore(item, notifList.firstChild);
    } else {
      notifList.appendChild(item);
    }
  });

  socket.on('notifications_read', ({ ids }) => {
    document.querySelectorAll('.notif-item.unread').forEach(el => {
      if (ids.includes(parseInt(el.dataset.id))) el.classList.remove('unread');
    });
    updateBadge();
  });
}

document.getElementById('markAllRead')?.addEventListener('click', () => {
  const ids = [...notifList.querySelectorAll('.notif-item.unread')].map(el => parseInt(el.dataset.id));
  socket.emit('mark_read', { ids });
  notifList.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
  updateBadge();
});

function renderNotifications(notifications) {
  notifList.innerHTML = '';
  if (!notifications || notifications.length === 0) {
    notifList.innerHTML = '<div class="text-center text-muted py-4" style="font-size:13px">No notifications yet</div>';
    return;
  }
  notifications.forEach(n => notifList.appendChild(createNotifItem(n)));
  updateBadge();
}

function createNotifItem(n) {
  const div = document.createElement('div');
  div.className = `notif-item d-flex align-items-start gap-2 px-3 py-2 border-bottom${n.is_read ? '' : ' unread'}`;
  div.style.cssText = n.is_read ? 'border-color:var(--border);cursor:pointer' : 'background:rgba(124,58,237,.08);border-color:var(--border);cursor:pointer';
  div.dataset.id = n.id;

  const iconMap = {
    message: 'bi-chat-dots',
    reveal_request: 'bi-eye',
    reveal_accepted: 'bi-check-circle',
    chat_invite: 'bi-chat-quote',
  };
  const icon = iconMap[n.type] || 'bi-bell';

  div.innerHTML = `
    <div class="d-flex align-items-center justify-content-center flex-shrink-0"
         style="width:32px;height:32px;border-radius:50%;background:rgba(124,58,237,.15);color:var(--accent)">
      <i class="bi ${icon}" style="font-size:14px"></i>
    </div>
    <div class="flex-grow-1" style="min-width:0">
      <div style="font-size:13px;line-height:1.4">${escHtml(n.content)}</div>
      <div style="font-size:11px;color:var(--text-3)">${timeAgo(n.created_at)}</div>
    </div>
  `;
  div.addEventListener('click', () => {
    if (!n.is_read) {
      socket.emit('mark_read', { ids: [n.id] });
      div.classList.remove('unread');
      div.style.background = '';
      updateBadge();
    }
    if (n.link) window.location.href = n.link;
  });
  return div;
}

function updateBadge() {
  const unread = notifList.querySelectorAll('.notif-item.unread').length;
  notifBadge.textContent = unread;
  notifBadge.style.display = unread > 0 ? 'block' : 'none';
}

function timeAgo(dateStr) {
  const date = new Date(dateStr);
  const now = new Date();
  const diff = Math.floor((now - date) / 1000);
  if (diff < 60) return 'just now';
  if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
  if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
  return `${Math.floor(diff/86400)}d ago`;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
