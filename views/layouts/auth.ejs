<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %> | CampusConfess</title>
  <meta name="description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://campusconfess.co.in' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= title %> | CampusConfess">
  <meta property="og:description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://campusconfess.co.in' %>">
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://campusconfess.co.in/og-default.png' %>">
  <meta property="og:site_name" content="CampusConfess">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %> | CampusConfess">
  <meta name="twitter:description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://campusconfess.co.in/og-default.png' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="🎭">

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="[INSERT_GOOGLE_VERIFICATION_CODE]">

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CampusConfess",
    "url": "https://campusconfess.co.in",
    "description": "Anonymous college social platform"
  }
  </script>

  <!-- Google Analytics (Replace GA_MEASUREMENT_ID) -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'GA_MEASUREMENT_ID');
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body class="auth-body">
  <div class="auth-bg-orb orb1"></div>
  <div class="auth-bg-orb orb2"></div>
  <div class="auth-bg-orb orb3"></div>
  <%- include('../partials/flash') %>
  <%- body %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
