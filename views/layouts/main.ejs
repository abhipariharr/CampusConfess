<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= title %> | CampusConfess</title>
  <meta name="description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://campusconfess.co.in' %>">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= title %> | CampusConfess">
  <meta property="og:description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <meta property="og:url" content="<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : 'https://campusconfess.co.in' %>">
  <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://campusconfess.co.in/og-default.png' %>">
  <meta property="og:site_name" content="CampusConfess">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %> | CampusConfess">
  <meta name="twitter:description" content="<%= metaDesc || 'CampusConfess — Anonymous college social platform.' %>">
  <meta name="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : 'https://campusconfess.co.in/og-default.png' %>">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="🎭">

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="[INSERT_GOOGLE_VERIFICATION_CODE]">

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CampusConfess",
    "url": "https://campusconfess.co.in",
    "description": "Anonymous college social platform"
  }
  </script>

  <!-- Google Analytics (Replace GA_MEASUREMENT_ID) -->
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'GA_MEASUREMENT_ID');
  </script>
  <script async src="https://www.googletagmanager.com/gtag/js?id=GA_MEASUREMENT_ID"></script>

  <!-- Bootstrap 5 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
</head>
<body>
  <%- include('../partials/navbar') %>

  <main class="container-fluid px-2 px-md-4 py-3">
    <%- include('../partials/flash') %>
    <%- body %>
  </main>

  <!-- Instagram-style Bottom Navigation (mobile only) -->
  <% if (locals.user) { %>
  <nav class="bottom-nav">
    <div class="bottom-nav-items">
      <a href="/confessions" class="bottom-nav-btn <%= typeof title !== 'undefined' && title === 'Feed' ? 'active' : '' %>">
        <i class="bi bi-house<%= typeof title !== 'undefined' && title === 'Feed' ? '-fill' : '' %>"></i>
      </a>
      <a href="/match" class="bottom-nav-btn <%= typeof title !== 'undefined' && title === 'Find Matches' ? 'active' : '' %>">
        <i class="bi bi-heart<%= typeof title !== 'undefined' && title === 'Find Matches' ? '-fill' : '' %>"></i>
      </a>
      <a href="/confessions/new" class="bottom-nav-btn">
        <div class="bottom-nav-post"><i class="bi bi-plus-lg" style="font-size:18px"></i></div>
      </a>
      <a href="/chat" class="bottom-nav-btn <%= typeof title !== 'undefined' && title === 'Chat' ? 'active' : '' %>">
        <i class="bi bi-chat-dots<%= typeof title !== 'undefined' && title === 'Chat' ? '-fill' : '' %>"></i>
        <span id="chatBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:9px;display:none">0</span>
      </a>
      <a href="/profile" class="bottom-nav-btn <%= typeof title !== 'undefined' && title === 'My Profile' ? 'active' : '' %>">
        <div class="bottom-nav-avatar" style="background:<%= user.avatar_color||'#7c3aed' %>;outline:<%= typeof title !== 'undefined' && title === 'My Profile' ? '2px solid #fff' : 'none' %>;outline-offset:1px">
          <%= user.anon_username.charAt(0) %>
        </div>
      </a>
    </div>
  </nav>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <% if (locals.user) { %><script src="/socket.io/socket.io.js"></script><% } %>
  <% if (locals.pageScript) { %><script src="/js/<%= pageScript %>"></script><% } %>
</body>
</html>
