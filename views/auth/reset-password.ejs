<div class="auth-wrapper">
  <div class="auth-card">
    <div class="text-center mb-4">
      <span class="brand-icon fs-1"><i class="bi bi-mask"></i></span>
      <h1 class="brand-name fs-3 mt-2">New Password</h1>
      <p class="text-muted small">Choose a strong new password.</p>
    </div>
    <form action="/reset-password/<%= token %>" method="POST" id="resetForm">
      <div class="mb-3">
        <label for="password" class="form-label">New Password</label>
        <div class="input-group-icon">
          <i class="bi bi-lock"></i>
          <input type="password" id="password" name="password" class="form-control" placeholder="Min 8 chars, 1 uppercase, 1 number" required minlength="8">
        </div>
      </div>
      <div class="mb-4">
        <label for="confirm_password" class="form-label">Confirm Password</label>
        <div class="input-group-icon">
          <i class="bi bi-lock-fill"></i>
          <input type="password" id="confirm_password" name="confirm_password" class="form-control" placeholder="Repeat password" required>
        </div>
      </div>
      <button type="submit" class="btn btn-gradient w-100 py-2"><i class="bi bi-check-lg me-2"></i>Update Password</button>
    </form>
    <hr class="brd my-4">
    <p class="text-center text-muted small mb-0"><a href="/login" class="text-accent"><i class="bi bi-arrow-left me-1"></i>Back to Login</a></p>
  </div>
</div>
