<div class="auth-split-wrapper">

  <!-- ── Left Panel: Brand showcase (hidden on small screens) ── -->
  <div class="auth-brand-panel" aria-hidden="true">
    <div class="brand-panel-inner">
      <div class="brand-logo-hero">
        <div class="brand-icon-ring">🎭</div>
      </div>
      <h1 class="brand-panel-title">CampusConfess</h1>
      <p class="brand-panel-sub">The anonymous social space for your campus community.</p>

      <div class="brand-features">
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-shield-check-fill"></i></div>
          <div>
            <div class="feature-title">100% Anonymous</div>
            <div class="feature-desc">Your identity is never revealed.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-heart-fill"></i></div>
          <div>
            <div class="feature-title">Find Your Match</div>
            <div class="feature-desc">Connect with like-minded students.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-chat-dots-fill"></i></div>
          <div>
            <div class="feature-title">Private Chats</div>
            <div class="feature-desc">Conversations that stay between you two.</div>
          </div>
        </div>
      </div>

      <!-- Floating testimony cards -->
      <div class="floating-cards-wrap">
        <div class="floating-card fc-1">
          <span class="fc-avatar" style="background:#7c3aed">S</span>
          <div>
            <div class="fc-text">"Finally a safe space to be honest 💜"</div>
            <div class="fc-user">SilentWanderer42</div>
          </div>
        </div>
        <div class="floating-card fc-2">
          <span class="fc-avatar" style="background:#be185d">M</span>
          <div>
            <div class="fc-text">"Found my best friend anonymously 🎉"</div>
            <div class="fc-user">MysticOwl99</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Right Panel: Login form ── -->
  <div class="auth-form-panel">
    <div class="auth-form-inner">

      <!-- Mobile-only brand header -->
      <div class="auth-mobile-brand">
        <div class="mobile-brand-icon">🎭</div>
        <span class="mobile-brand-name">CampusConfess</span>
      </div>

      <div class="auth-form-header">
        <h2 class="auth-form-title">Welcome back</h2>
        <p class="auth-form-subtitle">Sign in to your anonymous account</p>
      </div>

      <form action="/login" method="POST" id="loginForm" novalidate>

        <div class="auth-field-group">
          <label for="email" class="auth-label">College Email</label>
          <div class="auth-input-wrap">
            <i class="bi bi-envelope-fill auth-input-icon"></i>
            <input
              type="email"
              id="email"
              name="email"
              class="auth-input"
              placeholder="you@university.edu"
              required
              autocomplete="email"
            >
          </div>
        </div>

        <div class="auth-field-group">
          <label for="password" class="auth-label">
            Password
            <a href="/forgot-password" class="auth-forgot-link" tabindex="-1">Forgot password?</a>
          </label>
          <div class="auth-input-wrap">
            <i class="bi bi-lock-fill auth-input-icon"></i>
            <input
              type="password"
              id="password"
              name="password"
              class="auth-input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            >
            <button type="button" class="auth-toggle-pw" onclick="togglePw()" tabindex="-1" aria-label="Toggle password visibility">
              <i class="bi bi-eye" id="pwIcon"></i>
            </button>
          </div>
        </div>

        <div class="auth-remember-row">
          <label class="auth-checkbox-label">
            <input type="checkbox" id="remember_me" name="remember_me" value="1" class="auth-checkbox">
            <span class="auth-checkmark"></span>
            <span>Remember me for 30 days</span>
          </label>
        </div>

        <button type="submit" class="auth-submit-btn" id="loginBtn">
          <span class="btn-text">Sign In</span>
          <i class="bi bi-arrow-right btn-arrow"></i>
        </button>

      </form>

      <div class="auth-divider"><span>or</span></div>

      <p class="auth-switch-text">
        Don't have an account?
        <a href="/signup" class="auth-switch-link">Create one for free ✨</a>
      </p>

      <p class="auth-footer-note">
        <i class="bi bi-shield-lock-fill"></i>
        End-to-end anonymity guaranteed
      </p>

    </div>
  </div>

</div>

<script>
function togglePw() {
  const i = document.getElementById('password');
  const icon = document.getElementById('pwIcon');
  i.type = i.type === 'password' ? 'text' : 'password';
  icon.className = i.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
}
document.getElementById('loginForm').addEventListener('submit', function(e) {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:16px;height:16px;border-width:2px"></span> Signing in…';
});
</script>
