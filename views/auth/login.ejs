<div class="auth-wrapper">
  <div class="auth-card">

    <!-- Logo -->
    <div class="text-center mb-4">
      <div style="width:64px;height:64px;border-radius:20px;background:linear-gradient(135deg,#a855f7,#f472b6);display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 1rem">🎭</div>
      <h2 class="brand-name mb-1">CampusWhisper</h2>
      <p style="color:var(--text-3);font-size:.85rem">Welcome back 👋 Your secrets are safe.</p>
    </div>

    <form action="/login" method="POST" id="loginForm">
      <div class="mb-3">
        <label for="email" class="form-label">College Email</label>
        <div class="input-group-icon">
          <i class="bi bi-envelope-fill"></i>
          <input type="email" id="email" name="email" class="form-control" placeholder="you@university.edu" required autocomplete="email">
        </div>
      </div>
      <div class="mb-3">
        <label for="password" class="form-label d-flex justify-content-between align-items-center">
          <span>Password</span>
          <a href="/forgot-password" style="color:#c084fc;font-size:.78rem;font-weight:600">Forgot password?</a>
        </label>
        <div class="input-group-icon">
          <i class="bi bi-lock-fill"></i>
          <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required autocomplete="current-password">
          <button type="button" class="toggle-pw" onclick="togglePw()" tabindex="-1"><i class="bi bi-eye" id="pwIcon"></i></button>
        </div>
      </div>
      <div class="mb-4 d-flex justify-content-between align-items-center">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="remember_me" name="remember_me" value="1">
          <label class="form-check-label" for="remember_me" style="font-size:.82rem;color:var(--text-2)">Remember me for 30 days</label>
        </div>
      </div>
      <button type="submit" class="btn btn-glow w-100 py-2 mb-3" id="loginBtn" style="font-size:1rem">
        Login →
      </button>
    </form>

    <div style="text-align:center;position:relative;margin-bottom:1.25rem">
      <hr style="border-color:var(--border-2)">
      <span style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:var(--bg-card);padding:0 .75rem;font-size:.75rem;color:var(--text-3)">or</span>
    </div>

    <p class="text-center mb-0" style="font-size:.875rem;color:var(--text-2)">
      New here? <a href="/signup" style="color:#c084fc;font-weight:700">Create an anonymous account ✨</a>
    </p>
  </div>
</div>

<script>
function togglePw() {
  const i = document.getElementById('password');
  const icon = document.getElementById('pwIcon');
  i.type = i.type === 'password' ? 'text' : 'password';
  icon.className = i.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
}
document.getElementById('loginForm').addEventListener('submit', function() {
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Logging in...';
});
</script>
