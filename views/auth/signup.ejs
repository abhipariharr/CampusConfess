<div class="auth-split-wrapper">

  <!-- ── Left Panel: Brand showcase ── -->
  <div class="auth-brand-panel" aria-hidden="true">
    <div class="brand-panel-inner">
      <div class="brand-logo-hero">
        <div class="brand-icon-ring">🎭</div>
      </div>
      <h1 class="brand-panel-title">Join the Community</h1>
      <p class="brand-panel-sub">Create your anonymous identity and start sharing.</p>

      <div class="brand-features">
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-person-badge-fill"></i></div>
          <div>
            <div class="feature-title">Anonymous Identity</div>
            <div class="feature-desc">Random username, zero trace of your real self.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-people-fill"></i></div>
          <div>
            <div class="feature-title">Campus Network</div>
            <div class="feature-desc">Only verified students from your college.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-stars"></i></div>
          <div>
            <div class="feature-title">Free Forever</div>
            <div class="feature-desc">No subscriptions, no hidden fees.</div>
          </div>
        </div>
      </div>

      <div class="floating-cards-wrap">
        <div class="floating-card fc-1">
          <span class="fc-avatar" style="background:#0891b2">C</span>
          <div>
            <div class="fc-text">"The only place I can be truly myself 🌟"</div>
            <div class="fc-user">CrypticFox23</div>
          </div>
        </div>
        <div class="floating-card fc-2">
          <span class="fc-avatar" style="background:#b45309">N</span>
          <div>
            <div class="fc-text">"3000+ students already confessing daily!"</div>
            <div class="fc-user">NightOwlStudent</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Right Panel: Signup form ── -->
  <div class="auth-form-panel">
    <div class="auth-form-inner auth-form-inner--signup">

      <!-- Mobile brand -->
      <div class="auth-mobile-brand">
        <div class="mobile-brand-icon">🎭</div>
        <span class="mobile-brand-name">CampusConfess</span>
      </div>

      <div class="auth-form-header">
        <h2 class="auth-form-title">Create your account</h2>
        <p class="auth-form-subtitle">Anonymous by default. Safe by design.</p>
      </div>

      <!-- Privacy badge -->
      <div class="auth-privacy-badge">
        <i class="bi bi-shield-check-fill" style="color:#a855f7;font-size:1.1rem;flex-shrink:0"></i>
        <p>
          <strong>Privacy First:</strong> Your real name is for verification only —
          <strong style="color:#c084fc">never visible to anyone.</strong>
          You'll appear as a randomly generated anonymous username.
        </p>
      </div>

      <form action="/signup" method="POST" id="signupForm" novalidate>

        <div class="auth-fields-row">
          <div class="auth-field-group">
            <label for="real_name" class="auth-label">Full Name <span class="auth-label-note">(private)</span></label>
            <div class="auth-input-wrap">
              <i class="bi bi-person-badge-fill auth-input-icon"></i>
              <input type="text" id="real_name" name="real_name" class="auth-input" placeholder="Your real name — kept private" required minlength="2" maxlength="80">
            </div>
          </div>

          <div class="auth-field-group">
            <label for="gender" class="auth-label">I identify as…</label>
            <div class="auth-input-wrap">
              <i class="bi bi-gender-neuter auth-input-icon"></i>
              <select id="gender" name="gender" class="auth-input auth-select" required>
                <option value="" disabled selected>Select gender</option>
                <option value="male">Male</option>
                <option value="female">Female</option>
                <option value="other">Other / Prefer not to say</option>
              </select>
            </div>
          </div>
        </div>

        <div class="auth-field-group">
          <label for="email" class="auth-label">Email</label>
          <div class="auth-input-wrap">
            <i class="bi bi-envelope-fill auth-input-icon"></i>
            <input type="email" id="email" name="email" class="auth-input" placeholder="youremail@gmail.com" required autocomplete="email">
          </div>
        </div>

        <div class="auth-field-group">
          <label for="password" class="auth-label">Password</label>
          <div class="auth-input-wrap">
            <i class="bi bi-lock-fill auth-input-icon"></i>
            <input type="password" id="password" name="password" class="auth-input" placeholder="Min 8 chars, 1 uppercase, 1 number" required minlength="8">
            <button type="button" class="auth-toggle-pw" onclick="togglePw('password','pwIcon')" tabindex="-1" aria-label="Toggle password">
              <i class="bi bi-eye" id="pwIcon"></i>
            </button>
          </div>
          <!-- Strength bars -->
          <div class="pw-strength-bars" id="pwStrengthBars">
            <div class="pw-bar" id="bar1"></div>
            <div class="pw-bar" id="bar2"></div>
            <div class="pw-bar" id="bar3"></div>
            <div class="pw-bar" id="bar4"></div>
          </div>
          <div class="pw-strength-label" id="pwStrengthLabel"></div>
        </div>

        <div class="auth-field-group">
          <label for="confirm_password" class="auth-label">Confirm Password</label>
          <div class="auth-input-wrap">
            <i class="bi bi-lock-fill auth-input-icon"></i>
            <input type="password" id="confirm_password" name="confirm_password" class="auth-input" placeholder="Repeat your password" required>
            <button type="button" class="auth-toggle-pw" onclick="togglePw('confirm_password','cpwIcon')" tabindex="-1" aria-label="Toggle confirm password">
              <i class="bi bi-eye" id="cpwIcon"></i>
            </button>
          </div>
          <div class="pw-match-label" id="pwMatch"></div>
        </div>

        <button type="submit" class="auth-submit-btn" id="signupBtn">
          <span class="btn-text">Create Anonymous Account</span>
          <i class="bi bi-arrow-right btn-arrow"></i>
        </button>

      </form>

      <div class="auth-divider"><span>or</span></div>

      <p class="auth-switch-text">
        Already have an account?
        <a href="/login" class="auth-switch-link">Sign in →</a>
      </p>

      <p class="auth-footer-note">
        <i class="bi bi-shield-lock-fill"></i>
        End-to-end anonymity guaranteed
      </p>

    </div>
  </div>

</div>

<script>
function togglePw(id, iconId) {
  const i = document.getElementById(id);
  const icon = document.getElementById(iconId);
  i.type = i.type === 'password' ? 'text' : 'password';
  icon.className = i.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
}

const pw  = document.getElementById('password');
const cpw = document.getElementById('confirm_password');
const bars   = ['bar1','bar2','bar3','bar4'].map(id => document.getElementById(id));
const strLbl = document.getElementById('pwStrengthLabel');
const matchEl = document.getElementById('pwMatch');
const colors  = ['','#f87171','#fb923c','#22d3ee','#4ade80'];
const labels  = ['','Too weak 😬','Getting there 😐','Almost! 🙂','Strong 💪'];

pw.addEventListener('input', () => {
  const v = pw.value;
  let score = 0;
  if (v.length >= 8) score++;
  if (/[A-Z]/.test(v)) score++;
  if (/[0-9]/.test(v)) score++;
  if (/[^A-Za-z0-9]/.test(v)) score++;
  bars.forEach((b,i) => b.style.background = i < score ? colors[score] : 'var(--border)');
  strLbl.textContent = score > 0 ? labels[score] : '';
  strLbl.style.color = colors[score] || '';
  checkMatch();
});

cpw.addEventListener('input', checkMatch);

function checkMatch() {
  if (!cpw.value) { matchEl.textContent = ''; return; }
  if (cpw.value === pw.value) {
    matchEl.innerHTML = '<span style="color:#4ade80"><i class="bi bi-check-circle-fill me-1"></i>Passwords match</span>';
  } else {
    matchEl.innerHTML = '<span style="color:#f87171"><i class="bi bi-x-circle-fill me-1"></i>Passwords don\'t match</span>';
  }
}

document.getElementById('signupForm').addEventListener('submit', (e) => {
  if (cpw.value !== pw.value) { e.preventDefault(); return; }
  const btn = document.getElementById('signupBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:16px;height:16px;border-width:2px"></span> Creating account…';
});
</script>
