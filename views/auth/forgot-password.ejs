<div class="auth-split-wrapper">

  <!-- ── Left Panel: Brand showcase (hidden on small screens) ── -->
  <div class="auth-brand-panel" aria-hidden="true">
    <div class="brand-panel-inner">
      <div class="brand-logo-hero">
        <div class="brand-icon-ring">🎭</div>
      </div>
      <h1 class="brand-panel-title">CampusConfess</h1>
      <p class="brand-panel-sub">The anonymous social space for your campus community.</p>

      <div class="brand-features">
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-shield-check-fill"></i></div>
          <div>
            <div class="feature-title">100% Anonymous</div>
            <div class="feature-desc">Your identity is never revealed.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-key-fill"></i></div>
          <div>
            <div class="feature-title">Secure Recovery</div>
            <div class="feature-desc">Reset link sent straight to your inbox.</div>
          </div>
        </div>
        <div class="brand-feature-item">
          <div class="feature-icon-wrap"><i class="bi bi-lock-fill"></i></div>
          <div>
            <div class="feature-title">Privacy First</div>
            <div class="feature-desc">Your data is always protected.</div>
          </div>
        </div>
      </div>

      <!-- Floating cards -->
      <div class="floating-cards-wrap">
        <div class="floating-card fc-1">
          <span class="fc-avatar" style="background:#7c3aed">S</span>
          <div>
            <div class="fc-text">"Finally a safe space to be honest 💜"</div>
            <div class="fc-user">SilentWanderer42</div>
          </div>
        </div>
        <div class="floating-card fc-2">
          <span class="fc-avatar" style="background:#be185d">M</span>
          <div>
            <div class="fc-text">"Found my best friend anonymously 🎉"</div>
            <div class="fc-user">MysticOwl99</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Right Panel: Forgot password form ── -->
  <div class="auth-form-panel">
    <div class="auth-form-inner">

      <!-- Mobile-only brand header -->
      <div class="auth-mobile-brand">
        <div class="mobile-brand-icon">🎭</div>
        <span class="mobile-brand-name">CampusConfess</span>
      </div>

      <div class="auth-form-header">
        <h2 class="auth-form-title">Forgot password?</h2>
        <p class="auth-form-subtitle">Enter your email and we'll send you a reset link.</p>
      </div>

      <!-- Info badge -->
      <div class="auth-privacy-badge" style="margin-bottom:1.5rem">
        <i class="bi bi-info-circle-fill" style="color:#c084fc;font-size:1.1rem;margin-top:1px;flex-shrink:0"></i>
        <p>We'll send a secure password-reset link to your registered  email. Check your spam folder if it doesn't arrive within a minute.</p>
      </div>

      <form action="/forgot-password" method="POST" id="forgotForm" novalidate>

        <div class="auth-field-group">
          <label for="email" class="auth-label">Email Address</label>
          <div class="auth-input-wrap">
            <i class="bi bi-envelope-fill auth-input-icon"></i>
            <input
              type="email"
              id="email"
              name="email"
              class="auth-input"
              placeholder="youremail@gmail.com"
              required
              autocomplete="email"
            >
          </div>
        </div>

        <button type="submit" class="auth-submit-btn" id="forgotBtn">
          <i class="bi bi-send-fill"></i>
          <span class="btn-text">Send Reset Link</span>
          <i class="bi bi-arrow-right btn-arrow"></i>
        </button>

      </form>

      <div class="auth-divider"><span>or</span></div>

      <p class="auth-switch-text">
        Remembered it?
        <a href="/login" class="auth-switch-link"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
      </p>

      <p class="auth-footer-note">
        <i class="bi bi-shield-lock-fill"></i>
        End-to-end anonymity guaranteed
      </p>

    </div>
  </div>

</div>

<script>
document.getElementById('forgotForm').addEventListener('submit', function(e) {
  const btn = document.getElementById('forgotBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width:16px;height:16px;border-width:2px"></span> Sending…';
});
</script>
