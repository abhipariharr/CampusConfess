# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Admin@1234
DB_NAME=campuswhisper

# ─── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-this-to-a-random-secret-string

